module.exports = async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') return res.status(200).end();
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

  const ANT_KEY = process.env.ANTHROPIC_API_KEY;
  if (!ANT_KEY) return res.status(500).json({ error: 'API key not configured.' });

  const { analysisData: data, allContent = [], listingsFound = {} } = req.body || {};
  if (!data) return res.status(400).json({ error: 'Missing analysisData' });

  const ANT_H = {
    'Content-Type': 'application/json',
    'x-api-key': ANT_KEY,
    'anthropic-version': '2023-06-01',
  };

  const system = 'You are a senior GEO analyst. Produce a thorough report worth $150-250. Always return 5-7 findings minimum. Be specific to actual content. Score honestly. Return ONLY valid JSON — no markdown, no backticks.';

  const contentBlock = allContent.length > 0
    ? allContent.map(c => '--- ' + c.source + ': ' + (c.url || '') + ' ---\n' + (c.content || '').slice(0, 2500)).join('\n\n')
    : 'No content retrieved.';

  let userMessage;

  if (data.path === 'AC') {
    const inputDesc = data.inputType === 'url' ? 'URL: ' + data.url : 'Business: ' + data.businessQuery;
    userMessage = 'Comprehensive GEO analysis.\n' + inputDesc + '\nIndustry: ' + data.industry + '\nSources: ' + allContent.length + '\n\nCONTENT:\n' + contentBlock + '\n\nReturn this JSON:\n{"score":<0-100>,"aiView":"<2-3 sentences about AI visibility>","strengths":"<2-3 specific strengths>","weaknesses":"<2-3 specific gaps>","entity":"<entity statement with category, location, differentiator>","bizDesc":"<100-150 word AI-optimized description>","faqs":[{"q":"<AI query>","a":"<specific answer>"}],"positioning":["<query-specific statement>","<statement 2>","<statement 3>"],"schemaNote":"<platform-specific instruction>","listingsConsistency":"<consistency observation>","detectedProduct":"<main product>","detectedProductDesc":"<one sentence>","detectedCustomer":"<who>","detectedPrice":"<price or empty>","sourcesAnalyzed":<array of source names>}\n\n5 FAQs minimum. 3 positioning statements. Score honestly: no schema=max45, basic schema=max65, full GEO=70+.';
  } else {
    const socialBlock = allContent.length > 0 ? '\nSOCIAL:\n' + contentBlock : '';
    userMessage = 'GEO analysis — no website.\nBusiness: ' + data.bizName + '\nLocation: ' + data.location + '\nIndustry: ' + data.industry + '\nDescription: ' + data.bizDesc + '\nBio: ' + (data.currentBio || 'None') + socialBlock + '\n\nReturn JSON:\n{"score":<0-40>,"aiView":"<what AI finds>","strengths":"<what works>","weaknesses":"<gaps>","gbpDesc":"<750 char GBP description>","gbpFaqs":[{"q":"","a":""}],"directory":"<directory description>","pageHeadline":"<headline>","pageDesc":"<2 paragraphs>","pageServices":"<3-4 services>","pageFaqs":[{"q":"","a":""}],"listingsConsistency":"<observation>"}\n\n3 GBP FAQs minimum. 3 page FAQs minimum.';
  }

  try {
    const claudeRes = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: ANT_H,
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 2500,
        system: system,
        messages: [{ role: 'user', content: userMessage }],
      }),
    });

    const claudeData = await claudeRes.json();

    if (claudeData.error) {
      return res.status(400).json({ error: 'Claude error: ' + claudeData.error.message });
    }

    const text = (claudeData.content || [])
      .filter(b => b.type === 'text')
      .map(b => b.text)
      .join('');

    const clean = text.replace(/^```json\s*/,'').replace(/\s*```$/,'').trim();

    if (!clean || clean[0] !== '{') {
      return res.status(400).json({ error: 'Non-JSON response: ' + clean.slice(0, 100) });
    }

    const result = JSON.parse(clean);
    result.pageCount     = allContent.length;
    result.listingsFound = listingsFound;
    result.sourcesRead   = allContent.map(c => ({ source: c.source }));

    return res.status(200).json({ result });

  } catch(err) {
    return res.status(500).json({ error: 'Analysis failed: ' + err.message });
  }
};

module.exports.config = { maxDuration: 55 };
